---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Vestige | Expedition Log" stickyFooter={true} pageId="page-home">
  <section class="landing-shell">
    <div class="hero">
      <div class="hero-meta">
        <p class="eyebrow">Incandescent-21://Vestige</p>
        <div class="status-row">
          <span class="status-badge danger">status: ACTIVE</span>
          <span class="status-badge neutral">signal: UNSTABLE</span>
          <span class="status-badge accent">downtime: 26,280H</span>
        </div>
      </div>
      <h1 class="hero-title">EXPEDITION SURVIVED</h1>
      <p class="lede">
        I've done it. I've survived UTS
      </p>
      <div class="cta-row">
        <a class="primary-button glitch" href="/blog">Enter archive</a>
        <a class="ghost-button glitch" href="/about">Meet the Prisoner</a>
      </div>
      <div class="metrics">
        <div class="metric">
          <p class="label">Artifacts Logged</p>
          <p class="value">{posts.length}</p>
        </div>
        <div class="metric">
          <p class="label">J*bs Applied to</p>
          <p class="value">283</p>
        </div>
        <div class="metric">
          <p class="label">Systems</p>
          <p class="value">NixOS · Hyprland · Helix</p>
        </div>
      </div>
    </div>

    <div class="panel-grid">
      <section class="panel">
        <header class="panel-head">
          <p class="eyebrow">Contact</p>
          <span class="divider"></span>
        </header>
        <ul class="dispatch-list contact-list">
          <li>
            <a class="contact-row" href="mailto:razushi.scve@proton.me">
              <span class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path>
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                </svg>
              </span>
              <span class="contact-text">razushi.scve@proton.me</span>
            </a>
          </li>
          <li>
            <a class="contact-row" href="https://matrix.to/#/@razushi:matrix.org" target="_blank" rel="noreferrer">
              <span class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 3h3a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1h-3"></path>
                  <path d="M8 21H5a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h3"></path>
                </svg>
              </span>
              <span class="contact-text">@razushi:matrix.org</span>
            </a>
          </li>
          <li>
            <a class="contact-row" href="https://github.com/Razushi" target="_blank" rel="noreferrer">
              <span class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                  <path d="M9 18c-4.51 2-5-2-7-2"></path>
                </svg>
              </span>
              <span class="contact-text">github.com/Razushi</span>
            </a>
          </li>
        </ul>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .landing-shell {
    position: relative;
    display: grid;
    gap: 1.5rem;
    padding: 0;
  }

  .grid-overlay {
    position: absolute;
    inset: 0.5rem 0.5rem 0 0.5rem;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 36px 36px;
    opacity: 0.35;
    pointer-events: none;
    mix-blend-mode: lighten;
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: var(--card-padding);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--bg) 70%, var(--bg-alt));
    border: none;
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--border) 55%, transparent),
      0 16px 40px color-mix(in srgb, var(--shader-color) 35%, transparent);
    font-family: var(--font-body);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;

    mix-blend-mode: screen;
    pointer-events: none;
    z-index: 0;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 20%, color-mix(in srgb, var(--accent-highlight) 12%, transparent), transparent 35%);
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
  }

  .hero > * {
    position: relative;
    z-index: 1;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .status-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
    background: color-mix(in srgb, var(--bg-alt) 70%, var(--bg));
  }

  .status-badge.danger {
    color: var(--accent-highlight);
    border-color: color-mix(in srgb, var(--accent-highlight) 40%, var(--border));
  }

  .status-badge.neutral {
    color: var(--text);
  }

  .status-badge.accent {
    color: var(--accent-highlight);
  }

  .hero-title {
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    margin: 0.4rem 0 0.35rem;
    letter-spacing: 0.12em;
    font-family: var(--font-display);
  }

  .lede {
    margin: 0 0 1rem;
    color: var(--muted);
    max-width: 880px;
    font-family: var(--font-body);
  }

  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .primary-button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 1.2rem;
    border-radius: var(--radius-md);
    background: var(--accent-highlight);
    color: var(--bg);
    border: 1px solid var(--accent-highlight);
    font-weight: 800;
    letter-spacing: 0.04em;
    text-decoration: none;
    box-shadow: 0 8px 20px color-mix(in srgb, var(--accent-highlight) 35%, transparent);
    transition: transform var(--transition), filter var(--transition);
    font-family: var(--font-display);
  }

  .glitch {
    position: relative;
    overflow: hidden;
  }

  .glitch::before,
  .glitch::after {
    content: '';
    position: absolute;
    inset: -2px;
    border: 1px solid color-mix(in srgb, var(--accent-highlight) 30%, #88e6ff);
    opacity: 0.65;
    pointer-events: none;
    transition: transform 120ms ease, opacity 120ms ease;
  }

  .glitch::before {
    transform: translate(-5px, -3px);
    mix-blend-mode: screen;
  }

  .glitch::after {
    border-color: color-mix(in srgb, var(--accent-highlight) 25%, #ff6a6a);
    transform: translate(4px, 2px);
    mix-blend-mode: screen;
  }

  .glitch:hover {
    filter: brightness(1.03);
  }

  .glitch:hover::before {
    transform: translate(-4px, -2px) skewX(-1deg);
    opacity: 0.82;
  }

  .glitch:hover::after {
    transform: translate(4px, 2px) skewX(1deg);
    opacity: 0.82;
  }

  .primary-button:hover {
    transform: translateY(-1px);
    filter: brightness(1.02);
    box-shadow:
      0 8px 20px color-mix(in srgb, var(--accent-highlight) 35%, transparent),
      inset 0 0 0 1px color-mix(in srgb, #66c8ff 70%, transparent),
      0 0 0 1px color-mix(in srgb, var(--accent-highlight) 60%, transparent);
  }


  .ghost-button.subtle {
    border-color: var(--border);
    color: var(--text);
    font-family: var(--font-display);
  }

  .metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .metric {
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--bg-alt) 55%, var(--bg));
    font-family: var(--font-body);
  }

  .label {
    margin: 0 0 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    color: var(--muted);
    font-family: var(--font-body);
  }

  .value {
    margin: 0;
    font-weight: 800;
    font-family: var(--font-body);
  }

  .panel-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--card-padding);
  }

  .panel {
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 85%, var(--bg-alt));
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 24px color-mix(in srgb, var(--shader-color) 24%, transparent);
    display: grid;
    gap: 0.75rem;
    padding: var(--card-padding);
    align-content: start;
    font-family: var(--font-body);
  }

  .panel-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    align-self: start;
  }

  .panel-head .eyebrow {
    margin: 0;
    min-height: 1em;
    display: inline-flex;
    align-items: center;
  }

  .divider {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }

  .dispatch-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }

  .dispatch-list li {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.9rem;
    display: block;
    background: color-mix(in srgb, var(--bg-alt) 60%, var(--bg));
  }

  .contact-list {
    display: grid;
    gap: 0.65rem;
  }

  .contact-row {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: inherit;
    text-decoration: none;
    transition: color var(--transition);
  }

  .contact-row:hover {
    color: var(--accent-highlight);
  }

  .contact-icon {
    display: inline-flex;
    width: 22px;
    height: 22px;
    align-items: center;
    justify-content: center;
  }

  .contact-icon svg {
    width: 20px;
    height: 20px;
  }

  .contact-text {
    font-size: 1rem;
    font-family: var(--font-display);
    letter-spacing: 0.02em;
  }

  .dispatch-title {
    margin: 0;
    font-weight: 800;
    font-family: var(--font-display);
  }

  .dispatch-body {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    font-family: var(--font-body);
  }

  .loadout-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.75rem;
  }

  .loadout-grid > div {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.75rem 0.85rem;
    background: color-mix(in srgb, var(--bg-alt) 55%, var(--bg));
    font-family: var(--font-body);
  }

  @media (max-width: 720px) {
    .hero-title {
      letter-spacing: 0.08em;
    }

    .dispatch-list li {
      grid-template-columns: 1fr;
      grid-template-areas:
        "dot title"
        "body body"
        "link link";
    }
  }
</style>
