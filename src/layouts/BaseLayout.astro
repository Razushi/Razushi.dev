---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/layout.css';
import '../styles/components.css';
import '../styles/prose.css';
import '../styles/utilities.css';

import Header from '../components/layout/Header.astro';
import CustomCursor from '../components/layout/CustomCursor.svelte';
import ViewportMarks from '../components/layout/ViewportMarks.astro';
import Breadcrumbs from '../components/navigation/Breadcrumbs.astro';
import { siteConfig } from '../data/site';
import type { Breadcrumb } from '../lib/blog/tree';

const {
  title = siteConfig.title,
  description = siteConfig.description,
  breadcrumbs = [],
  mainClass = '',
}: {
  title?: string;
  description?: string;
  breadcrumbs?: Breadcrumb[];
  mainClass?: string;
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.name}`;
const isHomePage = mainClass.split(/\s+/).includes('site-main--home');
const shouldAnimatePageEnter = !isHomePage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var preferLight = !stored && window.matchMedia('(prefers-color-scheme: light)').matches;
          if (stored === 'light' || preferLight) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>
    <style is:inline>
      :root {
        --spacing-1: 4px;
        --spacing-3: 12px;
        --spacing-4: 16px;
        --spacing-6: 24px;
      }

      html {
        background-color: #181818;
        color-scheme: dark;
        scrollbar-gutter: stable;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background-color: #181818;
      }

      .site-shell {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background-color: #181818;
        background-image: radial-gradient(
          ellipse 60% 60% at 100% 0%,
          rgb(233 210 180 / 13%) 0%,
          rgb(233 210 180 / 6%) 33%,
          rgb(233 210 180 / 3%) 66%,
          transparent 100%
        );
        background-repeat: no-repeat;
        background-position: top right;
        background-size: 180rem 180rem;
      }

      .post-shell__footer { border-top: none; }

      .post-header h1,
      .page-heading h1,
      .hero-panel h1,
      .post-list h3,
      .prose-flow h1,
      .prose-flow h2,
      .prose-flow h3,
      .prose-flow h4 {
        font-family: 'Geist', system-ui, sans-serif !important;
        font-weight: 500 !important;
      }

      /* Light mode backgrounds */
      html[data-theme='light'] {
        background-color: #f0ede9;
        color-scheme: light;
      }
      html[data-theme='light'] body { background-color: #f0ede9; }
      html[data-theme='light'] .site-shell {
        background-color: #f0ede9;
        background-image: radial-gradient(
          ellipse 60% 60% at 100% 0%,
          rgb(140 90 53 / 8%) 0%,
          rgb(140 90 53 / 4%) 33%,
          rgb(140 90 53 / 2%) 66%,
          transparent 100%
        );
      }

      /* Header always dark in light mode */
      html[data-theme='light'] .site-header {
        background: rgba(24, 24, 24, 0.92);
        border-bottom-color: #252525;
        box-shadow: 0 6px 13px rgba(24, 24, 24, 0.8);
      }

      /* Critical header layout — locked in before components.css loads */
      .site-header__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        gap: 16px;
        padding: 16px 24px;
      }
      .site-brand { flex: 0 0 auto; }
      .site-header__end { display: flex; align-items: center; gap: 24px; }
      .site-nav { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; }
      .site-nav > .site-nav__link + .site-nav__link { margin-left: 24px; }

      /* Nav link colours and typography — must exactly match components.css
         so there is zero visual difference before/after external CSS loads */
      .site-nav__link {
        color: #e9d2b4;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        padding: 0 0 4px;
        border: 0;
        font-family: 'Reddit Mono', system-ui, sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        line-height: 1;
      }
      .site-nav__link--active { color: #e6956d; }

      /* Theme toggle */
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        width: 24px;
        height: 24px;
        border: none;
        background: transparent;
        padding: 0;
        cursor: pointer;
        color: #e9d2b4;
      }

      .theme-toggle__icon {
        display: block;
        width: 24px;
        height: 24px;
      }

      /* Icon visibility */
      .theme-toggle__icon--moon { display: none; }
      html[data-theme='light'] .theme-toggle__icon--sun { display: none; }
      html[data-theme='light'] .theme-toggle__icon--moon { display: block; }

      /* Theme transition */
      html.theme-transitioning,
      html.theme-transitioning *,
      html.theme-transitioning *::before,
      html.theme-transitioning *::after {
        transition:
          background-color 250ms ease,
          color 250ms ease,
          border-color 250ms ease,
          box-shadow 250ms ease,
          text-shadow 250ms ease !important;
      }

      @media (prefers-reduced-motion: no-preference) {
        body[data-page-enter='pending'] .site-main:not(.site-main--home) > .post-gutter-rail,
        body[data-page-enter='pending'] .site-main:not(.site-main--home) .site-main__inner > * {
          opacity: 0;
          transform: none !important;
          filter: blur(10px);
          animation: none !important;
        }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/redditmono/v5/oPWL_kRmmu4oQ88oo13o4-rLRjs.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Noto+Sans+SC:wght@400;500;700&family=Reddit+Mono:wght@400;500;600;700&family=Share+Tech&family=Victor+Mono:ital,wght@0,400;0,500;1,300;1,400;1,500&display=swap"
    />
    <title>{pageTitle}</title>
  </head>

  <body data-page-enter={shouldAnimatePageEnter ? 'pending' : undefined}>
    <div class="site-shell">
      <CustomCursor client:load />
      <ViewportMarks />
      <Header currentPath={Astro.url.pathname} />

      <main id="content" class:list={['site-main', mainClass]}>
        <slot name="main-floating" />
        <div class="site-container site-main__inner">
          <Breadcrumbs items={breadcrumbs} />
          <slot />
        </div>
      </main>
    </div>

    {
      shouldAnimatePageEnter && (
        <script is:inline>
          const runPageEnter = () => {
            const body = document.body;
            if (!body || body.dataset.pageEnter !== 'pending') return;

            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              body.dataset.pageEnter = 'ready';
              return;
            }

            window.requestAnimationFrame(() => {
              window.requestAnimationFrame(() => {
                body.dataset.pageEnter = 'ready';
              });
            });
          };

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', runPageEnter, { once: true });
          } else {
            runPageEnter();
          }
        </script>
      )
    }
  </body>
</html>
