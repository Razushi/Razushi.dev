---
import "../styles/palette.css";

interface Crumb {
  label: string;
  href?: string;
}

const {
  title = "Vestige",
  description = "Personal writing & notes",
  breadcrumbs = [],
  pageId = "",
  stickyFooter = false,
}: {
  title?: string;
  description?: string;
  breadcrumbs?: Crumb[];
  pageId?: string;
  stickyFooter?: boolean;
} = Astro.props;

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isActive = (path: string) =>
  currentPath === path || currentPath.startsWith(`${path}/`);

const bodyClass = [
  "site-shell",
  pageId,
  stickyFooter ? "footer-sticky" : "footer-static",
]
  .filter(Boolean)
  .join(" ");
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (() => {
        const storageKey = "epithet-theme";
        const storageAccentKey = "epithet-accent";
        const root = document.documentElement;
        const safeGet = (key) => {
          try {
            return localStorage.getItem(key);
          } catch {
            return null;
          }
        };
        const storedTheme = safeGet(storageKey);
        const theme = storedTheme || "night";
        root.setAttribute("data-theme", theme);
        root.setAttribute("data-theme-state", theme);
        root.style.colorScheme = theme === "light" ? "light" : "dark";

        const storedAccent = safeGet(storageAccentKey);
        if (storedAccent) {
          root.style.setProperty("--accent-highlight", storedAccent);
          root.style.setProperty("--accent-teal", storedAccent);
          root.style.setProperty("--accent-copper", storedAccent);
        }

        // expose for later scripts and set the toggle state as soon as DOM is ready
        window.__vestigeTheme = { theme, accent: storedAccent };
        document.addEventListener("DOMContentLoaded", () => {
          const btn = document.getElementById("theme-toggle");
          if (!btn) return;
          btn.setAttribute("data-theme-state", theme);
          btn.setAttribute("aria-label", `Change theme (current: ${theme})`);
        });
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <div class="wrap nav">
        <a class={`nav-link brand ${isHome ? "active" : ""}`} href="/">Vestige</a>
        <nav class="nav-links">
          <a class={`nav-link ${isActive("/blog") ? "active" : ""}`} href="/blog">Blog</a>
          <a class={`nav-link ${isActive("/about") ? "active" : ""}`} href="/about">About</a>
        </nav>
        <button
          class="theme-toggle"
          type="button"
          id="theme-toggle"
          aria-label="Change theme"
        >
          <svg
            class="icon icon-sun"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <line x1="12" y1="3" x2="12" y2="5"></line>
            <line x1="12" y1="19" x2="12" y2="21"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="3" y1="12" x2="5" y2="12"></line>
            <line x1="19" y1="12" x2="21" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg
            class="icon icon-moon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
          >
            <path
              d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <svg
            class="icon icon-star"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="13" height="7" x="8" y="3" rx="1"></rect>
            <path d="m2 9 3 3-3 3"></path>
            <rect width="13" height="7" x="8" y="14" rx="1"></rect>
          </svg>
        </button>
      </div>
    </header>
    <div class="wrap page-wrap">
      <div class="grid-overlay" aria-hidden="true"></div>
      <div class="card-panel content-panel">
        {
          breadcrumbs.length > 0 && (
            <nav class="breadcrumb" aria-label="Breadcrumb">
              {breadcrumbs.map((crumb, index) => {
                const isLast = index === breadcrumbs.length - 1;
                return (
                  <>
                    {crumb.href && !isLast ? (
                      <a href={crumb.href}>{crumb.label}</a>
                    ) : (
                      <span class={isLast ? "current" : ""}>{crumb.label}</span>
                    )}
                    {!isLast && <span aria-hidden="true">/</span>}
                  </>
                );
              })}
            </nav>
          )
        }
        <slot />
      </div>
    </div>
    <footer
      class={`site-footer ${stickyFooter ? "footer-sticky" : "footer-static"}`}
    >
      <div class="wrap footer-bar">
        <div class="footer-text">
          Copyright © Razushi {new Date().getFullYear()}
        </div>
        <a
          class="footer-link"
          href="https://github.com/Razushi/razushi.dev"
          target="_blank"
          rel="noreferrer"
          aria-label="Site repository"
        >
          <svg
            class="footer-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m18 16 4-4-4-4"></path>
            <path d="m6 8-4 4 4 4"></path>
            <path d="m14.5 4-5 16"></path>
          </svg>
          <span class="sr-only">Site repository</span>
        </a>
      </div>
    </footer>
  </body>
</html>

<script>
  const themeOrder = ["dark", "light", "night"];
  const storageKey = "epithet-theme";
  const storageAccentKey = "epithet-accent";
  const root = document.documentElement;
  const btn = document.getElementById("theme-toggle");
  const storedAccent = (() => {
    try {
      return localStorage.getItem(storageAccentKey);
    } catch {
      return null;
    }
  })();
  const defaultAccent =
    storedAccent ||
    getComputedStyle(root).getPropertyValue("--accent-highlight").trim() ||
    "#d45658";

  const applyAccent = (accent) => {
    root.style.setProperty("--accent-highlight", accent);
    root.style.setProperty("--accent-teal", accent);
    root.style.setProperty("--accent-copper", accent);
  };

  const applyTheme = (theme) => {
    root.dataset.theme = theme;
    root.dataset.themeState = theme;
    applyAccent(storedAccent || defaultAccent);

    if (btn) {
      btn.setAttribute("data-theme-state", theme);
      btn.setAttribute("aria-label", `Change theme (current: ${theme})`);
    }
    try {
      localStorage.setItem(storageKey, theme);
    } catch (_err) {
      /* ignore storage errors */
    }
  };

  const stored = window.__vestigeTheme?.theme;
  const initial = stored || "night";
  applyTheme(initial);

  btn?.addEventListener("click", () => {
    const current = root.dataset.theme || "dark";
    const currentState = btn.getAttribute("data-theme-state") || current;
    const idx = themeOrder.indexOf(currentState);
    const next = themeOrder[(idx + 1) % themeOrder.length];
    applyTheme(next);
  });

</script>
