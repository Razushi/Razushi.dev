---
import { formatFullDate, formatRelativeDate } from '../../lib/blog/dates';
import type { BlogTreeNode } from '../../lib/blog/tree';

interface Props {
  nodes: BlogTreeNode[];
}

const { nodes } = Astro.props as Props;
---

{nodes.map((node) => (
  <div class="tree-item">
    {node.type === 'folder' ? (
      <details class="tree-folder" data-tree-folder-slug={node.slug}>
        <summary class="tree-folder__row">
          <span class="tree-folder__chevron" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="0.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </span>
          <span class="tree-folder__toggle" aria-hidden="true">
            <svg
              class="tree-folder__icon tree-folder__icon--closed"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
            >
              <path d="M2 4.75C2 3.784 2.784 3 3.75 3h4.971c.58 0 1.12.286 1.447.765l1.404 2.063c.046.069.124.11.207.11h8.471c.966 0 1.75.783 1.75 1.75V19.25A1.75 1.75 0 0 1 20.25 21H3.75A1.75 1.75 0 0 1 2 19.25Z" />
            </svg>
            <svg
              class="tree-folder__icon tree-folder__icon--open"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
            >
              <path d="M2 4.75C2 3.784 2.784 3 3.75 3h4.971c.58 0 1.12.286 1.447.765l1.404 2.063a.25.25 0 0 0 .207.11h6.224c.966 0 1.75.783 1.75 1.75v.117H5.408a.848.848 0 0 0 0 1.695h15.484a1 1 0 0 1 .995 1.102L21 19.25c-.106 1.05-.784 1.75-1.75 1.75H3.75A1.75 1.75 0 0 1 2 19.25V4.75Z" />
            </svg>
          </span>
          <span class="tree-folder__name">{node.label}</span>
          {node.mostRecentDate && (
            <time
              class="tree-folder__meta"
              datetime={node.mostRecentDate.toISOString()}
              title={formatFullDate(node.mostRecentDate)}
            >
              {formatRelativeDate(node.mostRecentDate)}
            </time>
          )}
        </summary>
        {node.children && node.children.length > 0 && (
          <div class="tree-children">
            <Astro.self nodes={node.children} />
          </div>
        )}
      </details>
    ) : (
      <a class="tree-post" href={`/blog/${node.slug}/`}>
        <span class="tree-post__dot" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="0.75"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"></path>
            <path d="M14 2v5a1 1 0 0 0 1 1h5"></path>
          </svg>
        </span>
        <span class="tree-post__title">{node.label}</span>
        {(node.record?.entry.data.pubDate || node.record?.entry.data.updatedDate) && (
          <time
            class="tree-post__date"
            datetime={(node.record?.entry.data.updatedDate ?? node.record?.entry.data.pubDate)?.toISOString()}
            title={formatFullDate(node.record?.entry.data.updatedDate ?? node.record?.entry.data.pubDate)}
          >
            {formatRelativeDate(node.record?.entry.data.updatedDate ?? node.record?.entry.data.pubDate)}
          </time>
        )}
      </a>
    )}
  </div>
))}
