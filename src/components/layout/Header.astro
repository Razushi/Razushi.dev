---
import { navigationLinks } from '../../data/navigation';
import { siteConfig } from '../../data/site';

const { currentPath = '/' }: { currentPath?: string } = Astro.props;

const isActive = (href: string) =>
  href === '/'
    ? currentPath === href
    : currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="site-header">
  <div class="site-header__inner">
    <a
      class:list={[
        'site-brand',
        'site-nav__link',
        isActive('/') && 'site-brand--active',
        isActive('/') && 'site-nav__link--active',
      ]}
      href="/"
      aria-current={isActive('/') ? 'page' : undefined}
    >
      {siteConfig.name}
    </a>

    <div class="site-header__end">
      <nav class="site-nav" aria-label="Primary">
        {navigationLinks.map((link) => (
          <a
            class:list={[
              'site-nav__link',
              isActive(link.href) && 'site-nav__link--active',
            ]}
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark mode">
      <svg class="theme-toggle__icon theme-toggle__icon--sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
      </svg>
      <svg class="theme-toggle__icon theme-toggle__icon--moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/>
      </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const html = document.documentElement;
      const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
      html.classList.add('theme-transitioning');
      if (next === 'light') {
        html.setAttribute('data-theme', 'light');
      } else {
        html.removeAttribute('data-theme');
      }
      localStorage.setItem('theme', next);
      setTimeout(() => html.classList.remove('theme-transitioning'), 300);
    });
  }
</script>
